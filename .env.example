// ═══════════════════════════════════════════════════════════════
// AI Interview Trainer — Environment Variables Template
// Copy this file to .env and fill in your values
// ═══════════════════════════════════════════════════════════════

# ── Server Configuration ──
NODE_ENV=development
PORT=3000
BACKEND_PORT=5000

# ── MongoDB Atlas Configuration ──
# IMPORTANT: If your password contains special characters (like #, @, /, :, etc.),
# you MUST URL-encode them (e.g., '#' becomes '%23', '@' becomes '%40').
# Syntax: mongodb+srv://<username>:<encoded_password>@<cluster_url>/<database_name>?options
MONGODB_URI=mongodb+srv://21amtics140_db_user:Vivek%23123@cluster0.ljvoxst.mongodb.net/interview-ai?retryWrites=true&w=majority&appName=Cluster0

# ── JWT Security Secrets ──
# Change these values to long random strings in production
JWT_ACCESS_SECRET=dev-access-secret-change-in-production-12345
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production-67890
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── IBM watsonx.ai Service Integration ──
# Set these to your credentials to enable live AI interview question generation & evaluation.
# If left blank or incorrect, the server will fallback to high-quality mock responses.
IBM_API_KEY=your-ibm-cloud-api-key
IBM_PROJECT_ID=your-watsonx-project-id
IBM_AUTH_URL=https://iam.cloud.ibm.com/identity/token
IBM_WATSONX_URL=https://us-south.ml.cloud.ibm.com/ml/v1/text/generation?version=2024-05-31
IBM_MODEL_ID=ibm/granite-3-8b-instruct

# ── IBM Cloud Object Storage (Future Use) ──
IBM_COS_ENDPOINT=
IBM_COS_API_KEY=
IBM_COS_INSTANCE_ID=
IBM_COS_BUCKET=

# ── Application URLs ──
CLIENT_URL=http://localhost:3000

# ── File Upload Constraints ──
MAX_FILE_SIZE=5242880
UPLOAD_PATH=backend/uploads
