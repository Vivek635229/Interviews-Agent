NODE_ENV=development
PORT=3000
BACKEND_PORT=5000

# MongoDB Atlas
MONGODB_URI="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority"

# JWT Secrets (Generate secure random strings for production)
JWT_ACCESS_SECRET="your_development_access_secret_here"
JWT_REFRESH_SECRET="your_development_refresh_secret_here"
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# IBM watsonx.ai
IBM_PROJECT_ID="your_ibm_project_id_here"
IBM_API_KEY="your_ibm_api_key_here"
IBM_AUTH_URL=https://iam.cloud.ibm.com/identity/token
IBM_WATSONX_URL=https://us-south.ml.cloud.ibm.com/ml/v1/text/generation?version=2024-05-31
IBM_MODEL_ID=ibm/granite-3-8b-instruct

# Frontend URL for CORS
CLIENT_URL=http://localhost:3000

# Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_PATH=backend/uploads
